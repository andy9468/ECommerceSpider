# 环境
SERVER_ENV=PROD

# 亚马逊配置
TYPE_WORDS_STR="玩具,手机"

# MySQL 连接参数
MYSQL_HOST="127.0.0.1"
MYSQL_PORT=3306
MYSQL_USER="root"
MYSQL_PASSWORD="your password"
MYSQL_DATABASE="e_commerce_spider"

# 并发数控制
MAX_CONCURRENT_TYPE=3
MAX_CONCURRENT_SEARCH=5
MAX_CONCURRENT_DETAIL=2

# 浏览器参数
HEADLESS=False
NO_IMGS=False
NO_JS=False

# 设置代理IP
PROXY=""
# 默认无代理ip格式：PROXY=""
# 代理ip格式：PROXY="http://127.0.0.1:7890"

# sqlalchemy配置
ON_ECHO=False